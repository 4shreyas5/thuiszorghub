# ============================================================
# AUTHENTICATION & DATABASE
# ============================================================

# Supabase - Public (required)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase - Server-side only (required)
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================
# APPLICATION SETTINGS
# ============================================================

# App Identity
NEXT_PUBLIC_APP_NAME=ThuisZorgHub
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_DESCRIPTION=Smart Software for Modern Homecare
NODE_ENV=development

# ============================================================
# INTERNATIONALIZATION
# ============================================================

# Default locale (nl or en)
NEXT_PUBLIC_DEFAULT_LOCALE=nl

# Supported locales
NEXT_PUBLIC_SUPPORTED_LOCALES=nl,en

# ============================================================
# API
# ============================================================

NEXT_PUBLIC_API_URL=http://localhost:3000/api

# ============================================================
# FEATURES & FLAGS
# ============================================================

# Feature flags
NEXT_PUBLIC_ENABLE_DEMO_MODE=false
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_NOTIFICATIONS=true

# ============================================================
# EMAIL & COMMUNICATION
# ============================================================

# SendGrid (optional, for transactional emails)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@thuiszorghub.nl

# ============================================================
# EXTERNAL SERVICES (optional)
# ============================================================

# Sentry (error tracking)
NEXT_PUBLIC_SENTRY_DSN=

# PostHog (product analytics)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# ============================================================
# SECURITY & SESSION
# ============================================================

# Session configuration (in seconds)
NEXT_PUBLIC_SESSION_TIMEOUT=3600
NEXT_PUBLIC_SESSION_REFRESH_INTERVAL=300

# CORS configuration
NEXT_PUBLIC_CORS_ORIGIN=http://localhost:3000
